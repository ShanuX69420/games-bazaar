# Git Aliases for Gamers Market Development
# Add these to your global git config with: git config --global include.path ~/.gitconfig_aliases

[alias]
    # Quick GitHub sync
    sync = "!bash ./github_sync.sh"
    
    # Quick rollback
    rollback = "!bash ./github_rollback.sh"
    
    # Quick status and log
    st = status
    lg = log --oneline --graph --decorate --all -10
    
    # Quick commit
    ac = "!git add . && git commit -m"
    
    # Quick push
    pp = push origin HEAD
    
    # Quick pull
    pl = pull origin HEAD
    
    # Undo last commit (keep changes)
    undo = reset --soft HEAD~1
    
    # Hard reset to specific commit
    hard-reset = "!f() { git reset --hard $1 && git push origin HEAD --force; }; f"
    
    # Create and switch to new branch
    cb = checkout -b
    
    # Switch branch
    co = checkout
    
    # List branches
    br = branch -a